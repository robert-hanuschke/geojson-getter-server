{
  "name": "geojson-getter-server",
  "version": "1.0.0",
  "description": "HTTP server exposing OSM relation GeoJSON resolution via OSM ID or Wikidata ID",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "lint": "eslint src/",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "geojson",
    "openstreetmap",
    "osm",
    "overpass",
    "wikidata",
    "geometry",
    "mapping"
  ],
  "author": "Robert Hanuschke (https://github.com/robert-hanuschke)",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "geojson-getter": "^1.0.0",
    "hono": "^4.12.18",
    "hono-pino": "^0.10.3",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@types/pino": "^7.0.5",
    "eslint": "^10.3.0",
    "jiti": "^2.7.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "overrides": {
    "osmtogeojson": {
      "@xmldom/xmldom": "^0.8.13"
    }
  }
}
